{
  "name": "mcp-author",
  "version": "0.1.0",
  "description": "Smart MCP Server Template Generator - Generate production-ready MCP servers in 60 seconds",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "template",
    "generator",
    "cli",
    "openapi",
    "typescript",
    "python"
  ],
  "author": "Georg Esada <gesada66@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/gesada66/mcp-author#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gesada66/mcp-author.git"
  },
  "bugs": {
    "url": "https://github.com/gesada66/mcp-author/issues"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "bin": {
    "mcp-author": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "templates/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && npm run copy-templates",
    "copy-templates": "cp -r src/templates dist/ 2>/dev/null || true",
    "build:watch": "tsc --watch",
    "dev": "npm run build && node dist/cli.js",
    "start": "node dist/cli.js",
    "test": "npm run test:unit && npm run test:component && npm run test:e2e && npm run test:regression",
    "test:all": "npm run validate && npm run test && npm run test:cypress",
    "test:complete": "npm run test:all && npm run test:visual && npm run test:performance && npm run test:playwright",
    "test:unit": "jest tests/unit --coverage --verbose",
    "test:component": "jest tests/component --verbose",
    "test:e2e": "jest tests/e2e --verbose --runInBand --forceExit",
    "test:regression": "jest tests/regression --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageReporters=html lcov text",
    "test:debug": "jest --debug --no-cache --runInBand",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:e2e": "cypress run --spec 'cypress/e2e/**/*.cy.js'",
    "cypress:visual": "cypress run --spec 'cypress/e2e/visual/**/*.cy.js'",
    "cypress:cli": "cypress run --spec 'cypress/e2e/cli/**/*.cy.js'",
    "cypress:server": "cypress run --spec 'cypress/e2e/server-validation/**/*.cy.js'",
    "cypress:components": "cypress run --spec 'cypress/e2e/components/**/*.cy.js'",
    "cypress:performance": "cypress run --spec 'cypress/e2e/performance/**/*.cy.js'",
    "cypress:accessibility": "cypress run --spec 'cypress/e2e/accessibility/**/*.cy.js'",
    "test:cypress": "npm run cypress:e2e",
    "test:visual": "npm run cypress:visual",
    "test:performance": "npm run cypress:performance",
    "playwright:install": "playwright install",
    "playwright:test": "playwright test",
    "playwright:test:headed": "playwright test --headed",
    "playwright:test:debug": "playwright test --debug",
    "playwright:test:ui": "playwright test --ui",
    "playwright:codegen": "playwright codegen",
    "playwright:report": "playwright show-report",
    "test:playwright": "npm run playwright:test",
    "test:browser": "npm run playwright:test",
    "quality:quick": "npm run test:unit && npm run test:component",
    "quality:comprehensive": "npm run test:complete",
    "quality:pre-commit": "npm run validate && npm run quality:quick",
    "quality:pre-merge": "npm run quality:comprehensive",
    "quality:pre-release": "npm run quality:comprehensive && npm run test:performance",
    "mcp-jest": "node mcp-jest-server.js",
    "mcp-jest:debug": "JEST_DEBUG=true node mcp-jest-server.js",
    "mcp-cypress": "node mcp-cypress-server.js",
    "mcp-cypress:debug": "CYPRESS_DEBUG=true node mcp-cypress-server.js",
    "mcp-playwright": "node mcp-playwright-server.js",
    "mcp-playwright:debug": "PLAYWRIGHT_DEBUG=true node mcp-playwright-server.js",
    "mcp:start-all": "concurrently \"npm run mcp-jest\" \"npm run mcp-cypress\" \"npm run mcp-playwright\"",
    "mcp:integrated-test": "npm run mcp-cypress -- run_integrated_jest_cypress",
    "dev:with-tests": "npm run build && npm run quality:quick",
    "dev:full-check": "npm run build && npm run quality:comprehensive",
    "dev:performance-check": "npm run build && npm run test:performance",
    "test:auth-matrix": "jest tests/**/*auth*.test.ts --verbose",
    "test:auth-python": "jest tests/**/*auth*python*.test.ts --verbose",
    "test:auth-typescript": "jest tests/**/*auth*typescript*.test.ts --verbose",
    "test:templates": "jest tests/**/template*.test.ts --verbose",
    "test:generators": "jest tests/unit/generators --coverage --verbose",
    "validate": "npm run lint && npm run typecheck && npm run build",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "lint:fix": "eslint src/**/*.ts tests/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/**/*.ts tests/**/*.ts",
    "clean": "rimraf dist coverage .nyc_output test-outputs cypress/screenshots cypress/videos",
    "pre-commit": "npm run quality:pre-commit",
    "prepublishOnly": "npm run clean && npm run validate && npm run test",
    "preversion": "npm run validate && npm run test",
    "postversion": "git push && git push --tags"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^11.1.0",
    "figlet": "^1.7.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "gradient-string": "^2.0.2",
    "handlebars": "^4.7.8",
    "inquirer": "^9.2.12",
    "js-yaml": "^4.1.0",
    "ora": "^7.0.1",
    "swagger-parser": "^10.0.3"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/fs-extra": "^11.0.4",
    "@types/gradient-string": "^1.1.6",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@playwright/test": "^1.40.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "mcp-jest": "github:josharsh/mcp-jest",
    "playwright": "^1.40.0",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/tests/**/*.test.ts",
      "**/tests/**/*.spec.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,js}",
      "!src/**/*.d.ts",
      "!src/cli.ts",
      "!src/templates/**",
      "!src/**/*.types.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 95,
        "functions": 95,
        "lines": 95,
        "statements": 95
      },
      "src/generators/": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      },
      "src/validation/": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      },
      "src/utils/": {
        "branches": 98,
        "functions": 98,
        "lines": 98,
        "statements": 98
      }
    },
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.ts"
    ],
    "testTimeout": 60000,
    "maxWorkers": 1,
    "verbose": true
  }
}
